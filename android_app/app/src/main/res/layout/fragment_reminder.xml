<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.ReminderFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/prayer_reminder_title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/selected_city_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/reminder_prayers_label"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_fajr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/prayer_name_fajr" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_sunrise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/prayer_name_sunrise" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_dhuhr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/prayer_name_dhuhr" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_asr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/prayer_name_asr" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_maghrib"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/prayer_name_maghrib_iftar" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_isha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/prayer_name_isha" />

        <TextView
            android:id="@+id/reminder_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/reminder_loading"
            android:textSize="16sp" />
    </LinearLayout>
</ScrollView>
