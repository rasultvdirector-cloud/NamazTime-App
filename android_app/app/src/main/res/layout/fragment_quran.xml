<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.QuranFragment">

    <ScrollView
        android:id="@+id/quran_scroll_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_page_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/quran_section_title"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/screen_title_text"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/quran_section_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/quran_section_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/quran_entry_subtitle_text" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_audio_quran"
            android:layout_width="match_parent"
            android:layout_height="@dimen/quran_entry_card_height"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/imsak_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_quran_entry_listen"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/quran_entry_card_padding">

                <ImageView
                    android:layout_width="@dimen/quran_entry_icon_size"
                    android:layout_height="@dimen/quran_entry_icon_size"
                    android:alpha="0.98"
                    android:src="@drawable/ic_quran_listen"
                    app:tint="@color/white" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/card_audio_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/quran_audio_tab"
                        android:textColor="@color/white"
                        android:textSize="@dimen/quran_entry_title_text"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/card_audio_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/quran_audio_card_subtitle"
                        android:textColor="#EAF4EF"
                        android:textSize="@dimen/quran_entry_subtitle_text" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_read_quran"
                android:layout_width="0dp"
                android:layout_height="@dimen/quran_entry_compact_card_height"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/imsak_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_quran_entry_read"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/quran_entry_card_padding">

                    <ImageView
                        android:layout_width="@dimen/quran_entry_compact_icon_size"
                        android:layout_height="@dimen/quran_entry_compact_icon_size"
                        android:alpha="0.96"
                        android:src="@drawable/ic_quran_book"
                        app:tint="@color/white" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/card_read_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/quran_read_card_title"
                            android:textColor="@color/white"
                            android:textSize="@dimen/quran_entry_compact_title_text"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/card_read_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/quran_read_card_subtitle"
                            android:textColor="#F7EED6"
                            android:textSize="@dimen/quran_entry_compact_subtitle_text"
                            android:maxLines="2" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_allah_names"
                android:layout_width="0dp"
                android:layout_height="@dimen/quran_entry_compact_card_height"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/imsak_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_quran_entry_names"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/quran_entry_card_padding">

                    <TextView
                        android:layout_width="@dimen/quran_entry_compact_icon_size"
                        android:layout_height="@dimen/quran_entry_compact_icon_size"
                        android:gravity="center"
                        android:text="الله"
                        android:textColor="@color/white"
                        android:textSize="@dimen/quran_entry_compact_arabic_text"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/card_names_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/quran_allah_names_tab"
                            android:textColor="@color/white"
                            android:textSize="@dimen/quran_entry_compact_title_text"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/card_names_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/quran_allah_names_card_subtitle"
                            android:textColor="#F9F0DA"
                            android:textSize="@dimen/quran_entry_compact_subtitle_text"
                            android:maxLines="2" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/quran_content_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/surface_soft_blue"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/screen_page_padding">

                <TextView
                    android:id="@+id/quran_mode_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/quran_read_card_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/quran_content_title_text"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/quran_mode_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/quran_read_hint"
                    android:textColor="@color/text_secondary" />

                <LinearLayout
                    android:id="@+id/quran_download_progress_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_quran_audio_badge"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/quran_download_progress_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/quran_audio_download_in_progress"
                        android:textColor="@color/accent_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/quran_download_progress_bar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="10dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/bg_quran_audio_progress" />

                    <TextView
                        android:id="@+id/quran_download_progress_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <Button
                    android:id="@+id/quran_back_to_suras"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/quran_back_to_suras"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/quran_font_controls"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:text="@string/quran_font_size_label"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/quran_font_decrease"
                        android:layout_width="60dp"
                        android:layout_height="40dp"
                        android:minHeight="40dp"
                        android:padding="0dp"
                        android:text="@string/quran_font_decrease"
                        android:textAllCaps="false"
                        android:textSize="18sp" />

                    <Button
                        android:id="@+id/quran_font_increase"
                        android:layout_width="60dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:minHeight="40dp"
                        android:padding="0dp"
                        android:text="@string/quran_font_increase"
                        android:textAllCaps="false"
                        android:textSize="18sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/quran_audio_controls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/quran_audio_now_playing_card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_quran_audio_panel"
                            android:orientation="vertical"
                            android:paddingStart="12dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="10dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:baselineAligned="false"
                                android:gravity="top"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/quran_audio_now_playing_title"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="@string/quran_audio_now_playing_idle"
                                        android:textColor="@color/text_primary"
                                        android:textSize="15sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:id="@+id/quran_audio_now_playing_subtitle"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="3dp"
                                        android:ellipsize="end"
                                        android:maxLines="1"
                                        android:text="@string/quran_audio_play_hint"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="11sp" />

                                    <ProgressBar
                                        android:id="@+id/quran_audio_progress"
                                        style="?android:attr/progressBarStyleHorizontal"
                                        android:layout_width="match_parent"
                                        android:layout_height="6dp"
                                        android:layout_marginTop="8dp"
                                        android:layout_marginEnd="10dp"
                                        android:max="100"
                                        android:progress="0"
                                        android:progressDrawable="@drawable/bg_quran_audio_progress" />

                                    <TextView
                                        android:id="@+id/quran_audio_progress_label"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:gravity="start"
                                        android:text="@string/quran_audio_progress_idle"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="10sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:gravity="center"
                                    android:orientation="vertical">

                                    <ImageButton
                                        android:id="@+id/quran_audio_play"
                                        android:layout_width="42dp"
                                        android:layout_height="32dp"
                                        android:background="@drawable/bg_audio_control"
                                        android:contentDescription="@string/quran_audio_play_button"
                                        android:padding="5dp"
                                        android:src="@drawable/ic_audio_play"
                                        app:tint="@color/text_primary" />

                                    <ImageButton
                                        android:id="@+id/quran_audio_pause"
                                        android:layout_width="42dp"
                                        android:layout_height="32dp"
                                        android:layout_marginTop="6dp"
                                        android:background="@drawable/bg_audio_control"
                                        android:contentDescription="@string/quran_audio_pause_button"
                                        android:padding="5dp"
                                        android:src="@drawable/ic_audio_pause"
                                        app:tint="@color/text_primary" />

                                    <ImageButton
                                        android:id="@+id/quran_audio_stop"
                                        android:layout_width="42dp"
                                        android:layout_height="32dp"
                                        android:layout_marginTop="6dp"
                                        android:background="@drawable/bg_audio_control_stop"
                                        android:contentDescription="@string/quran_audio_stop_button"
                                        android:padding="5dp"
                                        android:src="@drawable/ic_audio_stop"
                                        app:tint="@color/white" />
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/quran_audio_offline_controls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <Button
                        android:id="@+id/quran_audio_filter_all"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_quran_filter_active"
                        android:backgroundTint="@null"
                        android:text="@string/quran_audio_filter_all"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/quran_audio_filter_downloaded"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_quran_filter_inactive"
                        android:backgroundTint="@null"
                        android:text="@string/quran_audio_filter_downloaded"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <ListView
                android:id="@+id/quran_content_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="@android:color/transparent"
                android:dividerHeight="10dp"
                android:nestedScrollingEnabled="false"
                android:padding="10dp" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/quran_read_navigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/quran_prev_sura"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/quran_previous_sura"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/quran_next_sura"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/quran_next_sura"
                android:textAllCaps="false" />
        </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/quran_scroll_to_top"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="@string/quran_scroll_to_top"
        android:src="@android:drawable/arrow_up_float"
        android:visibility="gone"
        app:backgroundTint="@color/accent_primary"
        app:fabCustomSize="52dp"
        app:maxImageSize="24dp"
        app:tint="@color/white" />
</FrameLayout>
