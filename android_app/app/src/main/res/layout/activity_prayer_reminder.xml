<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E2A14"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/reminder_bismillah"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/reminder_fullscreen_header"
        android:textColor="#D5E8D4"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/reminder_prayer_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/reminder_prayer_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textColor="#D9F1DA"
        android:textSize="22sp" />

    <Button
        android:id="@+id/button_done"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginTop="36dp"
        android:backgroundTint="#4CAF50"
        android:text="@string/notification_action_stop"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/button_later"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#FFB74D"
        android:text="@string/reminder_open_app"
        android:textAllCaps="false"
        android:textColor="#1B1B1B"
        android:textSize="28sp"
        android:textStyle="bold" />
</LinearLayout>
