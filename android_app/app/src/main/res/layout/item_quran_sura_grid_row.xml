<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false"
    android:orientation="horizontal">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/left_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:id="@+id/left_card_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_quran_sura_card"
            android:gravity="center_vertical"
            android:minHeight="92dp"
            android:orientation="horizontal"
            android:padding="@dimen/quran_list_item_padding">

            <TextView
                android:id="@+id/left_sura_number"
                android:layout_width="@dimen/quran_list_badge_size"
                android:layout_height="@dimen/quran_list_badge_size"
                android:background="@drawable/bg_quran_audio_badge"
                android:gravity="center"
                android:textColor="@color/accent_primary"
                android:textSize="@dimen/quran_list_meta_text"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/left_sura_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/quran_list_title_text"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <Space
        android:layout_width="10dp"
        android:layout_height="1dp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/right_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:id="@+id/right_card_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_quran_sura_card"
            android:gravity="center_vertical"
            android:minHeight="92dp"
            android:orientation="horizontal"
            android:padding="@dimen/quran_list_item_padding">

            <TextView
                android:id="@+id/right_sura_number"
                android:layout_width="@dimen/quran_list_badge_size"
                android:layout_height="@dimen/quran_list_badge_size"
                android:background="@drawable/bg_quran_audio_badge"
                android:gravity="center"
                android:textColor="@color/accent_primary"
                android:textSize="@dimen/quran_list_meta_text"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/right_sura_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/quran_list_title_text"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
