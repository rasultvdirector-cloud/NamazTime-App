<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:layout_width="@dimen/quran_list_badge_size"
        android:layout_height="@dimen/quran_list_badge_size"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="10dp"
        android:alpha="0.65"
        android:src="@drawable/ic_quran_ornament" />

    <LinearLayout
        android:id="@+id/sura_card_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_quran_sura_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/quran_list_item_padding">

        <TextView
            android:id="@+id/sura_number"
            android:layout_width="@dimen/quran_list_badge_size"
            android:layout_height="@dimen/quran_list_badge_size"
            android:background="@drawable/bg_quran_audio_badge"
            android:gravity="center"
            android:textColor="@color/accent_primary"
            android:textSize="@dimen/quran_list_meta_text"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/sura_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/quran_list_title_text"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/sura_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/quran_list_meta_text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/sura_action_button"
                android:layout_width="@dimen/quran_list_action_width"
                android:layout_height="@dimen/quran_list_action_height"
                android:background="@drawable/bg_audio_control"
                android:text="@string/quran_audio_play_button"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/quran_list_action_text"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/sura_download_button"
                android:layout_width="@dimen/quran_list_action_width"
                android:layout_height="@dimen/quran_list_action_height"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_widget_action"
                android:text="@string/quran_audio_download_button"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/quran_list_action_text"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
