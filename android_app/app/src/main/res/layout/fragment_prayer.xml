<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="vertical"
    tools:context=".ui.PrayerFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/prayer_header_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFF1DD"
            android:orientation="horizontal"
            android:padding="@dimen/prayer_header_padding">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/gregorian_date_label"
                    android:textColor="#8B5E34"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/gregorian_date_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#1E1B16"
                    android:textSize="@dimen/prayer_date_text"
                    android:textStyle="bold"
                    tools:text="6 mart" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hijri_date_label"
                    android:textColor="#8B5E34"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/hijri_date_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#1E1B16"
                    android:textSize="@dimen/prayer_date_text"
                    android:textStyle="bold"
                    tools:text="10 ramazan" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/loading_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/prayer_loading_idle"
            android:textColor="#7C7468"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#EAEFF7"
            android:orientation="vertical"
            android:padding="@dimen/prayer_header_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/date_prev_button"
                    android:layout_width="@dimen/prayer_nav_button_size"
                    android:layout_height="@dimen/prayer_nav_button_size"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/prayer_prev_day"
                    android:src="@android:drawable/ic_media_previous" />

                <TextView
                    android:id="@+id/selected_day_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textColor="#1E1B16"
                    android:textSize="@dimen/prayer_selected_day_text"
                    android:textStyle="bold"
                    tools:text="Bu gün" />

                <Button
                    android:id="@+id/date_today_button"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/prayer_today_button_height"
                    android:minHeight="@dimen/prayer_today_button_height"
                    android:minWidth="0dp"
                    android:paddingStart="10dp"
                    android:paddingTop="0dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="2dp"
                    android:text="@string/prayer_today_button"
                    android:textSize="@dimen/prayer_today_button_text" />

                <ImageButton
                    android:id="@+id/date_next_button"
                    android:layout_width="@dimen/prayer_nav_button_size"
                    android:layout_height="@dimen/prayer_nav_button_size"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/prayer_next_day"
                    android:src="@android:drawable/ic_media_next" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/local_time_label"
                    android:textColor="#4A5B78"
                    android:textSize="@dimen/prayer_label_text"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/local_time_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:tag="no_scale_text"
                    android:textColor="#18212D"
                    android:textSize="@dimen/prayer_local_time_text"
                    android:textStyle="bold"
                    tools:text="15:52:08" />
            </LinearLayout>

            <TextView
                android:id="@+id/next_prayer_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#314763"
                android:textSize="@dimen/prayer_next_text"
                android:textStyle="bold"
                tools:text="Esr namazina 01:21 qalib" />

            <FrameLayout
                android:id="@+id/timeline_section"
                android:layout_width="match_parent"
                android:layout_height="@dimen/prayer_timeline_height"
                android:layout_marginTop="6dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_gravity="top|center_vertical"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="20dp"
                    android:background="@color/timeline_line" />

                <LinearLayout
                    android:id="@+id/timeline_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:weightSum="6">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/timeline_dot_1"
                            android:layout_width="@dimen/prayer_timeline_dot"
                            android:layout_height="@dimen/prayer_timeline_dot"
                            android:background="@android:color/darker_gray" />

                        <TextView
                            android:id="@+id/timeline_label_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:textSize="@dimen/prayer_timeline_label"
                            tools:text="Sübh" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/timeline_dot_2"
                            android:layout_width="@dimen/prayer_timeline_dot"
                            android:layout_height="@dimen/prayer_timeline_dot"
                            android:background="@android:color/darker_gray" />

                        <TextView
                            android:id="@+id/timeline_label_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:textSize="@dimen/prayer_timeline_label"
                            tools:text="Gün" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/timeline_dot_3"
                            android:layout_width="@dimen/prayer_timeline_dot"
                            android:layout_height="@dimen/prayer_timeline_dot"
                            android:background="@android:color/darker_gray" />

                        <TextView
                            android:id="@+id/timeline_label_3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:textSize="@dimen/prayer_timeline_label"
                            tools:text="Zöhr" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/timeline_dot_4"
                            android:layout_width="@dimen/prayer_timeline_dot"
                            android:layout_height="@dimen/prayer_timeline_dot"
                            android:background="@android:color/darker_gray" />

                        <TextView
                            android:id="@+id/timeline_label_4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:textSize="@dimen/prayer_timeline_label"
                            tools:text="Əsr" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/timeline_dot_5"
                            android:layout_width="@dimen/prayer_timeline_dot"
                            android:layout_height="@dimen/prayer_timeline_dot"
                            android:background="@android:color/darker_gray" />

                        <TextView
                            android:id="@+id/timeline_label_5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:textSize="@dimen/prayer_timeline_label"
                            tools:text="Məğrib" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <View
                            android:id="@+id/timeline_dot_6"
                            android:layout_width="@dimen/prayer_timeline_dot"
                            android:layout_height="@dimen/prayer_timeline_dot"
                            android:background="@android:color/darker_gray" />

                        <TextView
                            android:id="@+id/timeline_label_6"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:textSize="@dimen/prayer_timeline_label"
                            tools:text="İşa" />
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <GridLayout
            android:id="@+id/prayer_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:alignmentMode="alignMargins"
            android:columnCount="2"
            android:useDefaultMargins="true">

            <FrameLayout
                android:id="@+id/prayer_card_1"
                android:layout_width="0dp"
                android:layout_height="@dimen/prayer_card_height"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_prayer_fajr"
                android:clipToOutline="true">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.26"
                    android:scaleType="centerCrop"
                    android:src="@drawable/prayer_fajr" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/prayer_card_inner_padding">

                    <TextView
                        android:id="@+id/prayer_name_1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:gravity="center"
                        android:tag="no_scale_text"
                        android:textAlignment="center"
                        android:textColor="#6F4B24"
                        android:textSize="@dimen/prayer_card_title_text"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="Sübh namazı" />

                    <TextView
                        android:id="@+id/prayer_time_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:tag="no_scale_text"
                        android:textColor="#1A232D"
                        android:textSize="@dimen/prayer_card_time_text"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@+id/prayer_status_1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/prayer_name_1"
                        tools:text="05:22" />

                    <TextView
                        android:id="@+id/prayer_status_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:textColor="#8B5E34"
                        android:textSize="@dimen/prayer_card_state_text"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:text="Gözlənilir" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/prayer_card_2"
                android:layout_width="0dp"
                android:layout_height="@dimen/prayer_card_height"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_prayer_sunrise"
                android:clipToOutline="true">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.24"
                    android:scaleType="centerCrop"
                    android:src="@drawable/prayer_sunrise" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/prayer_card_inner_padding">

                    <LinearLayout
                        android:id="@+id/prayer_name_row_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="@dimen/prayer_card_icon_size"
                            android:layout_height="@dimen/prayer_card_icon_size"
                            android:contentDescription="@string/prayer_name_sunrise"
                            android:src="@drawable/ic_sunrise" />

                        <TextView
                            android:id="@+id/prayer_name_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:tag="no_scale_text"
                            android:textColor="#5A4D22"
                            android:textSize="@dimen/prayer_card_title_text"
                            android:textStyle="bold"
                            tools:text="Gün doğumu" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/prayer_time_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:tag="no_scale_text"
                        android:textColor="#2B251B"
                        android:textSize="@dimen/prayer_card_time_text"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/prayer_status_2"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/prayer_name_row_2"
                        app:layout_constraintVertical_bias="0.50"
                        tools:text="06:51" />

                    <TextView
                        android:id="@+id/prayer_status_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:textColor="#456244"
                        android:textSize="@dimen/prayer_card_state_text"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:text="Məlumat" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/prayer_card_3"
                android:layout_width="0dp"
                android:layout_height="@dimen/prayer_card_height"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_prayer_dhuhr"
                android:clipToOutline="true">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.22"
                    android:scaleType="centerCrop"
                    android:src="@drawable/prayer_dhuhr" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/prayer_card_inner_padding">

                    <TextView
                        android:id="@+id/prayer_name_3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:gravity="center"
                        android:tag="no_scale_text"
                        android:textAlignment="center"
                        android:textColor="#234F78"
                        android:textSize="@dimen/prayer_card_title_text"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="Zöhr namazı" />

                    <TextView
                        android:id="@+id/prayer_time_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:tag="no_scale_text"
                        android:textColor="#0F2436"
                        android:textSize="@dimen/prayer_card_time_text"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/prayer_status_3"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/prayer_name_3"
                        app:layout_constraintVertical_bias="0.50"
                        tools:text="13:18" />

                    <TextView
                        android:id="@+id/prayer_status_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:textColor="#355B87"
                        android:textSize="@dimen/prayer_card_state_text"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:text="Gözlənilir" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/prayer_card_4"
                android:layout_width="0dp"
                android:layout_height="@dimen/prayer_card_height"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_prayer_asr"
                android:clipToOutline="true">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.22"
                    android:scaleType="centerCrop"
                    android:src="@drawable/prayer_asr" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/prayer_card_inner_padding">

                    <TextView
                        android:id="@+id/prayer_name_4"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:gravity="center"
                        android:tag="no_scale_text"
                        android:textAlignment="center"
                        android:textColor="#6A4356"
                        android:textSize="@dimen/prayer_card_title_text"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="Əsr namazı" />

                    <TextView
                        android:id="@+id/prayer_time_4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:tag="no_scale_text"
                        android:textColor="#2E2119"
                        android:textSize="@dimen/prayer_card_time_text"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/prayer_status_4"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/prayer_name_4"
                        app:layout_constraintVertical_bias="0.50"
                        tools:text="16:53" />

                    <TextView
                        android:id="@+id/prayer_status_4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:textColor="#7A4F78"
                        android:textSize="@dimen/prayer_card_state_text"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:text="Qılınmayıb" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/prayer_card_5"
                android:layout_width="0dp"
                android:layout_height="@dimen/prayer_card_height"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_prayer_maghrib"
                android:clipToOutline="true">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.24"
                    android:scaleType="centerCrop"
                    android:src="@drawable/prayer_maghrib" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/prayer_card_inner_padding">

                    <TextView
                        android:id="@+id/prayer_name_5"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:gravity="center"
                        android:tag="no_scale_text"
                        android:textAlignment="center"
                        android:textColor="#FFF0C5"
                        android:textSize="@dimen/prayer_card_title_text"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="Məğrib" />

                    <TextView
                        android:id="@+id/prayer_time_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:tag="no_scale_text"
                        android:textColor="#FFF8F1"
                        android:textSize="@dimen/prayer_card_time_text"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/prayer_status_5"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/prayer_name_5"
                        app:layout_constraintVertical_bias="0.50"
                        tools:text="19:10" />

                    <TextView
                        android:id="@+id/prayer_status_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:textColor="#A45A20"
                        android:textSize="@dimen/prayer_card_state_text"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:text="Qılındı" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/prayer_card_6"
                android:layout_width="0dp"
                android:layout_height="@dimen/prayer_card_height"
                android:layout_columnWeight="1"
                android:background="@drawable/bg_prayer_isha"
                android:clipToOutline="true">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.22"
                    android:scaleType="centerCrop"
                    android:src="@drawable/prayer_isha" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/prayer_card_inner_padding">

                    <TextView
                        android:id="@+id/prayer_name_6"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:gravity="center"
                        android:tag="no_scale_text"
                        android:textAlignment="center"
                        android:textColor="#D4DFFF"
                        android:textSize="@dimen/prayer_card_title_text"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="İşa namazı" />

                    <TextView
                        android:id="@+id/prayer_time_6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:tag="no_scale_text"
                        android:textColor="#F7FAFF"
                        android:textSize="@dimen/prayer_card_time_text"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/prayer_status_6"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/prayer_name_6"
                        app:layout_constraintVertical_bias="0.50"
                        tools:text="20:41" />

                    <TextView
                        android:id="@+id/prayer_status_6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="1dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:textColor="#5B56A7"
                        android:textSize="@dimen/prayer_card_state_text"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:text="Gözlənilir" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </FrameLayout>
        </GridLayout>

        <LinearLayout
            android:id="@+id/today_summary_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="#F5EBDD"
            android:orientation="vertical"
            android:padding="@dimen/prayer_header_padding">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/today_imsak_iftar_title"
                android:textColor="#8B5E34"
                android:textSize="@dimen/prayer_summary_label_text"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="@dimen/prayer_summary_card_height"
                    android:layout_weight="1"
                    android:background="@drawable/bg_imsak_card"
                    android:clipToOutline="true">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:alpha="0.24"
                        android:scaleType="centerCrop"
                        android:src="@drawable/imsak" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/prayer_header_padding">

                        <TextView
                            android:id="@+id/today_imsak_label_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text="@string/today_imsak_label"
                            android:textAlignment="center"
                            android:textColor="#7A4A22"
                            android:textSize="@dimen/prayer_summary_label_text"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/today_imsak_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:autoSizeMaxTextSize="55sp"
                            android:autoSizeMinTextSize="28sp"
                            android:autoSizeStepGranularity="1sp"
                            android:autoSizeTextType="uniform"
                            android:maxLines="1"
                            android:tag="no_scale_text"
                            android:textColor="#1E1B16"
                            android:textSize="@dimen/prayer_card_time_text"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/today_imsak_label_text"
                            app:layout_constraintVertical_bias="0.55"
                            tools:text="05:22" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </FrameLayout>

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="@dimen/prayer_summary_card_height"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_iftar_card"
                    android:clipToOutline="true">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:alpha="0.24"
                        android:scaleType="centerCrop"
                        android:src="@drawable/iftar" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/prayer_header_padding">

                        <TextView
                            android:id="@+id/today_iftar_label_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text="@string/today_iftar_label"
                            android:textAlignment="center"
                            android:textColor="#A45A20"
                            android:textSize="@dimen/prayer_summary_label_text"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/today_iftar_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:autoSizeMaxTextSize="55sp"
                            android:autoSizeMinTextSize="28sp"
                            android:autoSizeStepGranularity="1sp"
                            android:autoSizeTextType="uniform"
                            android:maxLines="1"
                            android:tag="no_scale_text"
                            android:textColor="#1E1B16"
                            android:textSize="@dimen/prayer_card_time_text"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/today_iftar_label_text"
                            app:layout_constraintVertical_bias="0.55"
                            tools:text="19:10" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
