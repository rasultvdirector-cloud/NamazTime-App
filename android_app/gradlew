#!/usr/bin/env sh
set -e
APP_HOME=$(cd "$(dirname "$0")" && pwd)
if [ -f "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" ]; then
  exec java -cp "$APP_HOME/gradle/wrapper/gradle-wrapper.jar" org.gradle.wrapper.GradleWrapperMain "$@"
else
  echo "ERROR: gradle-wrapper.jar tapılmadı."
  echo "Android Studio açın və 'File > Project Structure > Sync Project with Gradle Files' edin."
  echo "Əgər terminaldan işlətmək istəyirsinizsə gradle-wrapper.jar faylını əlavə edin."
  exit 1
fi
